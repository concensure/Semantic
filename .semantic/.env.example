# Copy to .semantic/.env and fill with your real keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=

# Optional bridge security token
MCP_BRIDGE_TOKEN=change-me

# Optional: semantic API base for MCP bridge
SEMANTIC_BASE_URL=http://127.0.0.1:4317
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

