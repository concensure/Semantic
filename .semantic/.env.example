# Copy to `.semantic/.env` and replace placeholders only in your local environment.
PRIMARY_LLM_API_KEY=<PRIMARY_LLM_API_KEY_PLACEHOLDER>
SECONDARY_LLM_API_KEY=<SECONDARY_LLM_API_KEY_PLACEHOLDER>

# Optional bridge secret for local use only
MCP_BRIDGE_SECRET=<LOCAL_ONLY_SECRET_PLACEHOLDER>

# Optional: semantic API base for the bridge or companion tools
SEMANTIC_BASE_URL=<SEMANTIC_API_BASE_URL>
PRIMARY_LLM_MODEL=<PRIMARY_MODEL_NAME>
SECONDARY_LLM_MODEL=<SECONDARY_MODEL_NAME>

