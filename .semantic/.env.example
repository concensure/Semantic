# Copy to .semantic/.env and fill with your real keys.
OPENAI_API_KEY=<OPENAI_API_KEY_PLACEHOLDER>
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY_PLACEHOLDER>
GEMINI_API_KEY=<GEMINI_API_KEY_PLACEHOLDER>
OPENROUTER_API_KEY=<OPENROUTER_API_KEY_PLACEHOLDER>
TOGETHER_API_KEY=<TOGETHER_API_KEY_PLACEHOLDER>

# Optional bridge security token
MCP_BRIDGE_TOKEN=<LOCAL_BRIDGE_TOKEN_PLACEHOLDER>

# Optional: semantic API base for MCP bridge
SEMANTIC_BASE_URL=http://localhost:4317
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

